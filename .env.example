# Copia este archivo como ".env" y rellena tus datos reales.
# NUNCA subas el archivo ".env" a GitHub.

# --- Supabase ---
# Los encuentras en tu proyecto de Supabase > Project Settings > API
SUPABASE_URL=https://sjcebvhirufsvjroobuy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=pega_aqui_tu_service_role_key

# --- Servidor ---
PORT=3000

# --- Sesión del panel admin ---
SESSION_SECRET=cambia-esto-por-un-texto-largo-y-aleatorio

# --- Contraseña del panel admin ---
# NO pongas aquí la contraseña en texto plano.
# Genera el hash corriendo: npm run hash-password
# y pega aquí el resultado.
ADMIN_PASSWORD_HASH=
